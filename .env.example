# --- Claude API (fact generation + fact-check) ---
ANTHROPIC_API_KEY=sk-ant-...
# Sonnet-tier per architecture doc; override if desired
CLAUDE_MODEL=claude-sonnet-4-6

# --- Grok / xAI (cover image generation) ---
XAI_API_KEY=xai-...
GROK_IMAGE_MODEL=grok-2-image

# Testing: path to a local image file to use as the cover instead of calling
# the xAI API (jpg/png/webp/svg/gif). Leave unset for normal operation.
LOCAL_COVER_IMAGE=

# --- Artist imagery policy ---
# "stylized" (default, recommended) or "photoreal" (legal/platform risk — see README)
ARTIST_IMAGE_MODE=stylized

# --- Human review gate ---
# true = every post must be approved via Telegram before publish
REVIEW_REQUIRED=true
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=123456789

# --- Instagram Graph API ---
# Instagram Business/Creator account ID (not the username)
IG_USER_ID=17841400000000000
# Long-lived Page access token from your Meta developer app
META_ACCESS_TOKEN=EAAG...

# --- Media hosting ---
# The Instagram Graph API fetches carousel images by public URL.
# Serve the output/ dir publicly (npm run serve behind a reverse proxy, or a tunnel)
# and set the public base URL here, e.g. https://media.example.com
PUBLIC_MEDIA_BASE_URL=
MEDIA_SERVER_PORT=8787

# --- Storage / misc ---
DB_PATH=./data/state.db
OUTPUT_DIR=./output
POST_HANDLE=@electronic.music.facts

# --- AI cost & droplet-health dashboard (npm run metrics-server) ---
# Shared metrics store (all accounts write here so one dashboard sees everything).
# Deliberately not DB_PATH — leave the default so every account shares one file.
METRICS_DB_PATH=./data/metrics.db
# Dashboard HTTP port (binds 127.0.0.1; put Caddy + Basic auth in front).
METRICS_SERVER_PORT=8788
# Per-image price used to estimate Grok/xAI image cost. Verify against xAI pricing.
XAI_IMAGE_PRICE_USD=0.07

# --- Development ---
# true = stub Claude + Grok with canned data so the pipeline runs without API keys
MOCK_MODE=false
